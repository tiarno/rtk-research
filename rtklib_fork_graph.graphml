    <node id="tomojitakasu/RTKLIB">
      <data key="d0">0</data>
      <data key="d1">0</data>
      <data key="d2">upstream (official)</data>
      <data key="d3">repo</data>
      <data key="d4">official upstream</data>
      <data key="d5">verified</data>
      <data key="d6">Japan (Yamanashi)</data>
      <data key="d7">Original project by Tomoji Takasu; first released 2009, BSD-2-Clause license; ~1.8k forks / ~2.9k stars on GitHub</data>
      <data key="d8">https://github.com/tomojitakasu/RTKLIB</data>
    </node>
    <node id="rtklibexplorer/RTKLIB (Demo5)">
      <data key="d3">repo</data>
      <data key="d4">fork</data>
      <data key="d6">unknown</data>
      <data key="d5">verified</data>
      <data key="d7">Fork optimized for low-cost/u-blox receivers, based on RTKLIB 2.4.3, 937 stars/367 forks — appears to be the highest-traffic fork</data>
      <data key="d8">https://github.com/rtklibexplorer</data>
    </node>
    <node id="rtklibexplorer/rtklib-py">
      <data key="d3">repo</data>
      <data key="d4">derivative (python port)</data>
      <data key="d6">unknown</data>
      <data key="d5">verified</data>
      <data key="d7">Python implementation based on the Demo5 fork, PPK-only</data>
      <data key="d8">https://github.com/rtklibexplorer</data>
    </node>
    <node id="DATAGNSS fork">
      <data key="d3">repo</data>
      <data key="d4">fork</data>
      <data key="d6">unknown</data>
      <data key="d5">verified</data>
      <data key="d7">Version optimized for single/dual-frequency low-cost u-blox receivers, based on RTKLIB 2.4.3, kept synced to that branch</data>
      <data key="d8">https://docs.datagnss.com/open-source/</data>
    </node>
    <node id="RTKGPS+">
      <data key="d3">mobile app</data>
      <data key="d4">derivative (official Android frontend)</data>
      <data key="d6">unknown</data>
      <data key="d5">verified</data>
      <data key="d7">Official Android companion app for RTKLIB</data>
      <data key="d8">Google Play / rtklib.com</data>
    </node>
    <node id="Emlid Reach receivers">
      <data key="d3">commercial product</data>
      <data key="d4">firmware (suspected derivative)</data>
      <data key="d6">Russia (company origin) / sold globally</data>
      <data key="d5">community-sourced/unverified</data>
      <data key="d7">Commonly cited in the RTK community as RTKLIB-derived firmware; company has since relocated HQ. Needs firmware-level confirmation, not confirmed by vendor documentation reviewed so far.</data>
      <data key="d8">community discussion / needs direct verification</data>
    </node>
    <node id="ArduSimple boards">
      <data key="d3">commercial product</data>
      <data key="d4">firmware (suspected derivative)</data>
      <data key="d6">Spain</data>
      <data key="d5">community-sourced/unverified</data>
      <data key="d7">RTKLIB-compatible OEM boards marketed explicitly for RTKLIB use; unclear whether firmware itself embeds RTKLIB or just interoperates with the desktop/host-side library</data>
      <data key="d8">vendor site / needs direct verification</data>
    </node>
    <node id="u-blox-based OEM receiver boards (various small vendors)">
      <data key="d3">commercial product</data>
      <data key="d4">firmware (suspected derivative)</data>
      <data key="d6">Switzerland (u-blox chipset) + many integrators globally</data>
      <data key="d5">inferred</data>
      <data key="d7">Numerous small manufacturers integrate RTKLIB with u-blox modules per RTKLIB's own supported-receiver list; specific vendor/product identification not yet done</data>
      <data key="d8">inferred from RTKLIB documentation's supported receiver list</data>
    </node>
